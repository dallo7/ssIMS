# Copy to `.env` in the project root — the app loads it automatically (python-dotenv).
# Or export variables in your shell / systemd.

# --- Required in production (CPI_ENV=production) ---
# CPI_SECRET_KEY=
# Generate: python -c "import secrets; print(secrets.token_hex(32))"

# CPI_ENV=production

# Optional: browser tab title, PDF cover, API health "app" field (default: "Inventory" in production,
# "Smart-Shop Stock Inventory" in dev)
# CPI_APP_TITLE=My Company Inventory

# First deploy with NO inventory/demo rows (default when CPI_ENV=production if unset):
# CPI_SEED_MODE=minimal
# Optional one-shot first admin from env (remove password from env after first login):
# CPI_BOOTSTRAP_ADMIN_USERNAME=admin
# CPI_BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately
# Or leave password unset and run once:
#   python -m database.create_bootstrap_admin --username admin --password '...'
# Wipe all row data before go-live (destructive):
#   python -m database.clear_all_data --yes

# --- SQLite (default fallback; zero-config quick deploys) ---
# If neither CPI_DATABASE_URL nor CPI_PG_* is set, the app boots on SQLite at
#   /data/cpi_inventory.sqlite  (if /data exists, e.g. Render/Fly disk)
#   <project>/data/cpi_inventory.sqlite  (otherwise)
# Override location:
# CPI_SQLITE_PATH=/data/cpi_inventory.sqlite

# --- PostgreSQL (choose ONE style) ---

# (A) Single URL (password URL-encoded if it has special characters)
# CPI_DATABASE_URL=postgresql+psycopg://USER:PASS@host:5432/dbname?sslmode=require

# (B) Discrete variables (recommended for RDS; never commit real passwords to git)
# `dbname` in AWS/console maps to CPI_PG_DB (alias: CPI_PG_DATABASE).
# If the app times out: run `python -m database.check_tcp` — TCP must succeed before credentials matter.
# CPI_PG_HOST=your-db.xxxxx.eu-north-1.rds.amazonaws.com
# CPI_PG_PORT=5432
# CPI_PG_USER=postgres
# CPI_PG_PASSWORD=REPLACE_ME
# CPI_PG_DB=ss_ims
# CPI_PG_SSLMODE=require
# CPI_PG_CONNECT_TIMEOUT=10

# Local Postgres example (single URL):
# CPI_DATABASE_URL=postgresql+psycopg://cpi_user:change-me@127.0.0.1:5432/cpi_inventory

# Optional: first line of file is the URL (CI / secret managers)
# CPI_DATABASE_URL_FILE=/path/to/secret_file

# Connection / pool tuning (optional)
# CPI_DB_CONNECT_TIMEOUT=15
# CPI_PG_CONNECT_TIMEOUT=15
# CPI_PG_POOL_SIZE=5
# CPI_PG_MAX_OVERFLOW=10
# CPI_PG_POOL_TIMEOUT=30
# Production under concurrency: consider CPI_PG_POOL_SIZE=10 CPI_PG_MAX_OVERFLOW=20

# Bind address for python app.py / uvicorn
# CPI_HOST=0.0.0.0
# CPI_PORT=8050

# Dev only: CPI_DEBUG=true (forced false when CPI_ENV=production)
# CPI_DEBUG=true

# Behind nginx / TLS terminator: forward X-Forwarded-* and set:
# CPI_BEHIND_PROXY=1

# If users only use HTTPS, set (browser sends Secure cookies):
# CPI_SESSION_COOKIE_SECURE=1

# Alert engine (dev: eval on start + poll every 15 ticks; prod: eval off on start unless set,
# poll every 30 ticks; CPI_ALERT_POLL_MS defaults 60s dev / 120s prod).
# CPI_ALERT_EVAL_ON_START=0
# CPI_ALERT_EVAL_INTERVAL_TICKS=30
# CPI_ALERT_POLL_MS=120000

# --- Mobile / integration API ---
# Comma-separated origins allowed to call /api/v1/* from a browser.
# Mobile apps don't need CORS; set this only for web front-ends.
# CPI_API_CORS_ORIGINS=https://app.example.com,https://admin.example.com
